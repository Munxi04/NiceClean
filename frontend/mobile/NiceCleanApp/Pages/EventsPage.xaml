<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NiceCleanApp.Pages.EventsPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1A1A1A}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Grid Grid.Row="0"
              Padding="16,16,16,16"
              BackgroundColor="#3B6D11"
              ColumnDefinitions="Auto,*,Auto">

            <Button Grid.Column="0"
                    Text="←"
                    BackgroundColor="Transparent"
                    TextColor="White"
                    FontSize="20"
                    WidthRequest="44"
                    Clicked="OnBackClicked"
                    VerticalOptions="Center"/>

            <Label Grid.Column="1"
                   Text="🌿 Clean Walks"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="White"
                   VerticalOptions="Center"
                   Margin="4,0"/>

            <Button Grid.Column="2"
                    x:Name="CreateButton"
                    Text="+ New"
                    BackgroundColor="White"
                    TextColor="#3B6D11"
                    CornerRadius="20"
                    FontSize="13"
                    FontAttributes="Bold"
                    Padding="14,6"
                    VerticalOptions="Center"
                    Clicked="OnCreateEventClicked"/>
        </Grid>

        <!-- Body -->
        <Grid Grid.Row="1">

            <ActivityIndicator x:Name="BusyIndicator"
                               IsRunning="False"
                               IsVisible="False"
                               Color="#3B6D11"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"/>

            <VerticalStackLayout x:Name="EmptyState"
                                 IsVisible="False"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="10"
                                 Padding="40">
                <Label Text="🏃" FontSize="52" HorizontalOptions="Center"/>
                <Label Text="No events yet"
                       FontSize="18" FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"/>
                <Label Text="Organise a clean walk at a reported pollution spot!"
                       FontSize="13"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"
                       TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}"/>
                <Button Text="Organise a Walk"
                        BackgroundColor="#3B6D11" TextColor="White"
                        CornerRadius="12" Margin="0,8,0,0"
                        Clicked="OnCreateEventClicked"/>
            </VerticalStackLayout>

            <CollectionView x:Name="EventsCollection" Margin="0,6" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <!-- Card -->
                        <Border Margin="12,5"
                                Padding="0"
                                Stroke="{AppThemeBinding Light=#E8E8E8, Dark=#3A3A3A}"
                                StrokeThickness="1"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#2C2C2C}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.08"/>
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnEventTapped"
                                                      CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="8,*">
                                <!-- Status stripe -->
                                <BoxView Grid.Column="0" BackgroundColor="{Binding StatusColor}" WidthRequest="8"/>

                                <!-- Content -->
                                <Grid Grid.Column="1" Padding="14,12"
                                      RowDefinitions="Auto,Auto,Auto"
                                      ColumnDefinitions="*,Auto">

                                    <Label Grid.Row="0" Grid.Column="0"
                                           Text="{Binding LocationDisplay}"
                                           FontSize="15" FontAttributes="Bold"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}"/>

                                    <!-- Status badge -->
                                    <Border Grid.Row="0" Grid.Column="1"
                                            BackgroundColor="{Binding StatusColor}"
                                            Padding="8,3" StrokeThickness="0"
                                            VerticalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="8"/>
                                        </Border.StrokeShape>
                                        <Label Text="{Binding StatusLabel}" FontSize="11" TextColor="White"/>
                                    </Border>

                                    <Label Grid.Row="1" Grid.ColumnSpan="2"
                                           Text="{Binding DateDisplay}"
                                           FontSize="13" Margin="0,4,0,0"
                                           TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}"/>

                                    <Label Grid.Row="2" Grid.ColumnSpan="2"
                                           Text="{Binding HostDisplay}"
                                           FontSize="12" Margin="0,2,0,0"
                                           TextColor="{AppThemeBinding Light=#999999, Dark=#777777}"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <!-- Filter tabs -->
        <HorizontalStackLayout Grid.Row="2" Spacing="8" Padding="12,8" HorizontalOptions="Center">
            
            <Button x:Name="FilterPendingBtn" Text="Pending" Clicked="OnFilterPending"
                    BackgroundColor="#3B6D11" TextColor="White"
                    CornerRadius="20" FontSize="13" Padding="16,6"/>
            <Button x:Name="FilterOngoingBtn" Text="Ongoing" Clicked="OnFilterOngoing"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"
                    CornerRadius="20" FontSize="13" Padding="16,6"/>
            <Button x:Name="FilterEndedBtn"     Text="Ended"     Clicked="OnFilterEnded"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"
                    CornerRadius="20" FontSize="13" Padding="16,6"/>
        </HorizontalStackLayout>

    </Grid>
</ContentPage>

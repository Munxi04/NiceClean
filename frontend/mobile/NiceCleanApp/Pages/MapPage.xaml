<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
    x:Class="NiceCleanApp.Pages.MapPage"
    Title="Map"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*, Auto">

        <!-- Map fills the whole page -->
        <mapsui:MapView
            x:Name="MainMap"
            Grid.Row="0"
            Grid.RowSpan="2"
            MapClicked="OnMapClicked" />

        <!-- Place-pin mode banner (hidden by default) -->
        <Border
            x:Name="PlacingPinBanner"
            Grid.Row="0"
            BackgroundColor="#CC000000"
            IsVisible="False"
            VerticalOptions="Start"
            Margin="16,52,16,0"
            StrokeShape="RoundRectangle 10"
            StrokeThickness="0"
            Padding="12,8">
            <Label
                Text="📍 Tap anywhere on the map to place the pin"
                TextColor="White"
                FontSize="14"
                HorizontalOptions="Center" />
        </Border>

        <!-- Too-far banner (hidden by default) -->
        <Border
            x:Name="TooFarBanner"
            Grid.Row="0"
            BackgroundColor="#CC000000"
            IsVisible="False"
            VerticalOptions="Start"
            Margin="16,52,16,0"
            StrokeShape="RoundRectangle 10"
            StrokeThickness="0"
            Padding="0,8">
            <HorizontalStackLayout>
                <Label Text="📍" FontSize="16" VerticalOptions="Center" Padding="28,0" />
                <VerticalStackLayout>
                    <Label
                        Text="You must be within 100 meters of"
                        TextColor="White"
                        FontSize="14"
                        HorizontalOptions="Center"/>
                    <Label
                        Text="the location to place a pin there."
                        TextColor="White"
                        FontSize="14"
                        HorizontalOptions="Center"/>
                </VerticalStackLayout>
                <Label Text="📍" FontSize="16" VerticalOptions="Center" Padding="28,0" />
            </HorizontalStackLayout>
        </Border>

        <!-- Too-near banner (hidden by default) -->
        <Border
            x:Name="TooNearBanner"
            Grid.Row="0"
            BackgroundColor="#CC000000"
            IsVisible="False"
            VerticalOptions="Start"
            Margin="16,52,16,0"
            StrokeShape="RoundRectangle 10"
            StrokeThickness="0"
            Padding="0,8">
            <HorizontalStackLayout>
                <Label Text="📍" FontSize="16" VerticalOptions="Center" Padding="28,0" />
                <VerticalStackLayout>
                    <Label
                        Text="There's already a pin in this area."
                        TextColor="White"
                        FontSize="14"
                        HorizontalOptions="Center"/>
                    <Label
                        Text="The next step is to make an event!"
                        TextColor="White"
                        FontSize="14"
                        HorizontalOptions="Center"/>
                </VerticalStackLayout>
                <Label Text="📍" FontSize="16" VerticalOptions="Center" Padding="28,0" />
            </HorizontalStackLayout>
        </Border>

        <!-- Bottom tab bar -->
        <Border
            Grid.Row="1"
            BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 0"
            Padding="0,4,0,8">

            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-2" Radius="8" Opacity="0.12" />
            </Border.Shadow>

            <Grid ColumnDefinitions="*,*,*,*">

                <!-- Map tab -->
                <VerticalStackLayout Grid.Column="0" Spacing="2" HorizontalOptions="Center">
                    <Button
                        x:Name="MapTabButton"
                        Text="🗺"
                        FontSize="22"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"
                        BorderWidth="0"
                        Clicked="OnMapTabClicked"
                        HeightRequest="50"
                        WidthRequest="60" />
                </VerticalStackLayout>

                <!-- Place Pin tab -->
                <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="Center">
                    <Button
                        x:Name="PlacePinTabButton"
                        Text="📍"
                        FontSize="22"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"
                        BorderWidth="0"
                        Clicked="OnPlacePinTabClicked"
                        HeightRequest="50"
                        WidthRequest="60" />
                </VerticalStackLayout>

                <!-- Events tab -->
                <VerticalStackLayout Grid.Column="2" Spacing="2" HorizontalOptions="Center">
                    <Button
                        x:Name="EventsTabButton"
                        Text="👥"
                        FontSize="22"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"
                        BorderWidth="0"
                        Clicked="OnEventsTabClicked"
                        HeightRequest="50"
                        WidthRequest="60" />
                </VerticalStackLayout>

                <!-- Menu tab -->
                <VerticalStackLayout Grid.Column="3" Spacing="2" HorizontalOptions="Center">
                    <Button
                        x:Name="MenuTabButton"
                        Text="☰"
                        FontSize="22"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"
                        BorderWidth="0"
                        Clicked="OnMenuTabClicked"
                        HeightRequest="50"
                        WidthRequest="60" />
                </VerticalStackLayout>

            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════
             RIGHT-SIDE DRAWER (on top of everything)
             ══════════════════════════════════════════ -->
        <Grid
            x:Name="MenuOverlay"
            Grid.Row="0"
            Grid.RowSpan="2"
            IsVisible="False">

            <!-- Dim backdrop — tap to close -->
            <BoxView BackgroundColor="#66000000">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMenuBackdropTapped" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <!-- Sliding panel anchored to the right edge -->
            <Border
                x:Name="MenuPanel"
                HorizontalOptions="End"
                WidthRequest="280"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0">

                <Border.Clip>
                    <RectangleGeometry Rect="0,0,280,900" />
                </Border.Clip>

                <Grid RowDefinitions="Auto,*">

                    <!-- Drawer header -->
                    <Border
                        Grid.Row="0"
                        BackgroundColor="#3B6D11"
                        StrokeThickness="0"
                        Padding="4,8,8,8">
                        <Grid ColumnDefinitions="Auto,*,Auto" HorizontalOptions="Fill">
                            <!-- Back arrow (only visible on account view) -->
                            <Button
                                x:Name="MenuBackButton"
                                Grid.Column="0"
                                Text="‹"
                                FontSize="22"
                                TextColor="White"
                                BackgroundColor="Transparent"
                                BorderWidth="0"
                                HeightRequest="5"
                                WidthRequest="5"
                                IsVisible="False"
                                Clicked="OnMenuBackClicked"
                                Padding="0,0,0,4"/>
                            <Label
                                x:Name="MenuHeaderLabel"
                                Grid.Column="1"
                                Text="Menu"
                                TextColor="White"
                                FontSize="22"
                                FontAttributes="Bold"
                                VerticalOptions="Center"
                                Margin="12,0,0,0"/>
                            <!-- Close button -->
                            <Button
                                x:Name="MenuCloseButton"
                                Grid.Column="1"
                                Text="✕"
                                FontSize="18"
                                TextColor="White"
                                BackgroundColor="Transparent"
                                BorderWidth="0"
                                HeightRequest="36"
                                WidthRequest="36"
                                Clicked="OnMenuCloseClicked"
                                Margin="200,0,0,0"/>
                        </Grid>
                    </Border>

                    <!-- Sliding content area -->
                    <Grid 
                        Grid.Row="1" 
                        x:Name="DrawerContentArea" 
                        IsClippedToBounds="True">

                        <!-- Main menu content -->
                        <Grid x:Name="MainMenuContent" RowDefinitions="*,Auto">

                            <VerticalStackLayout
                            Grid.Row="0"
                            Padding="20"
                            Spacing="24">

                                <!-- Placeholder menu items for future use -->
                                <VerticalStackLayout Spacing="4">
                                    <Label
                                        Text="ACCOUNT"
                                        FontSize="11"
                                        FontAttributes="Bold"
                                        CharacterSpacing="1"
                                        TextColor="{AppThemeBinding Light=#999999, Dark=#777777}" />
                                    <Button
                                        Text="My Account"
                                        Margin="0,6,0,0"
                                        BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}"
                                        TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}"
                                        HorizontalOptions="Start"
                                        CornerRadius="8"
                                        HeightRequest="44"
                                        FontSize="14"
                                        BorderWidth="0"
                                        Clicked="OnAccountMenuItemClicked" />
                                </VerticalStackLayout>

                                <!-- Sign Out button -->
                                <Button Text="Sign Out"
                                    BackgroundColor="#3B6D11"
                                    TextColor="White"
                                    CornerRadius="8"
                                    HeightRequest="40"
                                    Clicked="OnSignOutClicked" />
                            </VerticalStackLayout>

                            <VerticalStackLayout
                                 Grid.Row="1"
                                 Padding="20"
                                 Spacing="12">

                                <!-- Divider -->
                                <BoxView
                                     HeightRequest="1"
                                     BackgroundColor="{AppThemeBinding Light=#EEEEEE, Dark=#333333}" />

                                <!-- Theme section -->
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">

                                    <!-- Light theme button -->
                                    <Border
                                         x:Name="LightThemeCard"
                                         Grid.Column="0"
                                         Padding="0,8"
                                         StrokeShape="RoundRectangle 10"
                                         StrokeThickness="0">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnLightThemeTapped" />
                                        </Border.GestureRecognizers>
                                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                            <Label
                                                 x:Name="LightThemeIcon"
                                                 Text="☀️"
                                                 FontSize="20"
                                                 HorizontalOptions="Center" />
                                        </VerticalStackLayout>
                                    </Border>

                                    <!-- Dark theme button -->
                                    <Border
                                         x:Name="DarkThemeCard"
                                         Grid.Column="1"
                                         Padding="0,8"
                                         StrokeShape="RoundRectangle 10"
                                         StrokeThickness="0">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnDarkThemeTapped" />
                                        </Border.GestureRecognizers>
                                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                            <Label
                                                 x:Name="DarkThemeIcon"
                                                 Text="🌙"
                                                 FontSize="20"
                                                 HorizontalOptions="Center" />
                                        </VerticalStackLayout>
                                    </Border>
                                </Grid>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- ACCOUNT VIEW (starts off-screen to the right) -->
                        <VerticalStackLayout
                            x:Name="AccountView"
                            Padding="20"
                            Spacing="20"
                            TranslationX="280">

                            <!-- User info card -->
                            <Border
                                Padding="16"
                                StrokeShape="RoundRectangle 12"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#EEEEEE, Dark=#333333}"
                                BackgroundColor="{AppThemeBinding Light=#F9F9F9, Dark=#2A2A2A}">
                                <VerticalStackLayout Spacing="8">
                                    <Label
                                        x:Name="MenuNicknameLabel"
                                        FontSize="17"
                                        FontAttributes="Bold"
                                        TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                                    <Label
                                        x:Name="MenuEmailLabel"
                                        FontSize="13"
                                        TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                                    <BoxView HeightRequest="1"
                                         Color="{AppThemeBinding Light=#EEEEEE, Dark=#333333}"
                                         Margin="0,4" />
                                    <HorizontalStackLayout Spacing="6">
                                        <Label Text="🚶" FontSize="13" />
                                        <Label
                                            x:Name="MenuWalksLabel"
                                            FontSize="13"
                                            TextColor="{AppThemeBinding Light=#444444, Dark=#CCCCCC}" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Border>

                            <!-- Delete account -->
                            <Button
                                Text="Delete Account"
                                BackgroundColor="#8B1A1A"
                                TextColor="White"
                                CornerRadius="8"
                                HeightRequest="44"
                                FontSize="14"
                                Clicked="OnDeleteAccountClicked" />
                        </VerticalStackLayout>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>

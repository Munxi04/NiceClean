<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
    x:Class="NiceCleanApp.Pages.MapPage"
    Title="Map"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*, Auto">

        <!-- Map fills the whole page -->
        <mapsui:MapView
            x:Name="MainMap"
            Grid.Row="0"
            Grid.RowSpan="2"
            MapClicked="OnMapClicked" />

        <!-- Place-pin mode banner (hidden by default) -->
        <Border
            x:Name="PlacingPinBanner"
            Grid.Row="0"
            BackgroundColor="#CC000000"
            IsVisible="False"
            VerticalOptions="Start"
            Margin="16,52,16,0"
            StrokeShape="RoundRectangle 10"
            StrokeThickness="0"
            Padding="12,8">
            <Label
                Text="📍 Tap anywhere on the map to place the pin"
                TextColor="White"
                FontSize="14"
                HorizontalOptions="Center" />
        </Border>

        <!-- Bottom tab bar -->
        <Border
            Grid.Row="1"
            BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 0"
            Padding="0,4,0,8">

            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-2" Radius="8" Opacity="0.12" />
            </Border.Shadow>

            <Grid ColumnDefinitions="*,*,*,*">

                <!-- Map tab -->
                <VerticalStackLayout
                    Grid.Column="0"
                    Spacing="2"
                    HorizontalOptions="Center">
                    <Button
                        Text="🗺"
                        FontSize="22"
                        BackgroundColor="Transparent"
                        Clicked="OnMapTabClicked"
                        HeightRequest="36"
                        WidthRequest="48" />
                    <Label
                        Text="Map"
                        FontSize="11"
                        HorizontalOptions="Center"
                        TextColor="#FF3300" />
                </VerticalStackLayout>

                <!-- Place Pin tab -->
                <VerticalStackLayout
                    Grid.Column="1"
                    Spacing="2"
                    HorizontalOptions="Center">
                    <Button
                        Text="📍"
                        FontSize="22"
                        BackgroundColor="Transparent"
                        Clicked="OnPlacePinTabClicked"
                        HeightRequest="36"
                        WidthRequest="48" />
                    <Label
                        Text="Report"
                        FontSize="11"
                        HorizontalOptions="Center"
                        TextColor="{AppThemeBinding Light=#666, Dark=#AAA}" />
                </VerticalStackLayout>

                <!-- Events tab -->
                <VerticalStackLayout
                    Grid.Column="2"
                    Spacing="2"
                    HorizontalOptions="Center">
                    <Button
                        Text="🧹"
                        FontSize="22"
                        BackgroundColor="Transparent"
                        Clicked="OnEventsTabClicked"
                        HeightRequest="36"
                        WidthRequest="48" />
                    <Label
                        Text="Cleanwalks"
                        FontSize="11"
                        HorizontalOptions="Center"
                        TextColor="{AppThemeBinding Light=#666, Dark=#AAA}" />
                </VerticalStackLayout>

                <!-- Menu tab -->
                <VerticalStackLayout
                    Grid.Column="3"
                    Spacing="2"
                    HorizontalOptions="Center">
                    <Button
                        Text="☰"
                        FontSize="22"
                        BackgroundColor="Transparent"
                        Clicked="OnMenuTabClicked"
                        HeightRequest="36"
                        WidthRequest="48" />
                    <Label
                        Text="Menu"
                        FontSize="11"
                        HorizontalOptions="Center"
                        TextColor="{AppThemeBinding Light=#666, Dark=#AAA}" />
                </VerticalStackLayout>

            </Grid>
        </Border>

    </Grid>
</ContentPage>

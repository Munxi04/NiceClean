<?xml version="1.0" encoding="utf-8"?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="NiceCleanApp.Pages.Controls.CreateEventPopup"
               Background="Transparent"
               CanBeDismissedByTappingOutsideOfPopup="False">

    <Border WidthRequest="320"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 16"
            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
            Padding="0">

        <VerticalStackLayout Spacing="0">

            <!-- Header bar -->
            <Grid Padding="20,16"
                  BackgroundColor="#3B6D11"
                  ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       Text="🌿 New Clean Walk"
                       FontSize="18" FontAttributes="Bold"
                       TextColor="White" VerticalOptions="Center"/>
                <Button Grid.Column="1"
                        Text="✕" Clicked="OnCloseClicked"
                        BackgroundColor="Transparent" TextColor="White"
                        FontSize="18" Padding="0"
                        WidthRequest="36" HeightRequest="36"
                        VerticalOptions="Start"/>
            </Grid>

            <!-- Form body -->
            <VerticalStackLayout Padding="20,16" Spacing="14">

                <!-- Pin picker -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="📍 Pollution Spot"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#888888, Dark=#AAAAAA}"/>
                    <Border Padding="4,0" StrokeThickness="1"
                            Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#444444}"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="{AppThemeBinding Light=#F9F9F9, Dark=#333333}">
                        <Picker x:Name="PinPicker"
                                Title="Select a pin…"
                                FontSize="14"
                                TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}"
                                TitleColor="{AppThemeBinding Light=#999999, Dark=#777777}"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Date -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="📅 Date"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#888888, Dark=#AAAAAA}"/>
                    <Border Padding="12,6" StrokeThickness="1"
                            Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#444444}"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="{AppThemeBinding Light=#F9F9F9, Dark=#333333}">
                        <DatePicker x:Name="EventDatePicker"
                                    FontSize="14"
                                    TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Time -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="🕐 Time"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#888888, Dark=#AAAAAA}"/>
                    <Border Padding="12,6" StrokeThickness="1"
                            Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#444444}"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="{AppThemeBinding Light=#F9F9F9, Dark=#333333}">
                        <TimePicker x:Name="EventTimePicker"
                                    FontSize="14"
                                    TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Error -->
                <Label x:Name="ErrorLabel"
                       IsVisible="False"
                       TextColor="#E53935"
                       FontSize="13"
                       HorizontalTextAlignment="Center"/>

                <!-- Busy -->
                <ActivityIndicator x:Name="BusyIndicator"
                                   IsRunning="False" IsVisible="False"
                                   Color="#3B6D11" HorizontalOptions="Center"/>

                <!-- Actions -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,2,0,0">
                    <Button Grid.Column="0"
                            Text="Cancel"
                            Clicked="OnCloseClicked"
                            BackgroundColor="{AppThemeBinding Light=#EEEEEE, Dark=#3A3A3A}"
                            TextColor="{AppThemeBinding Light=#444444, Dark=#CCCCCC}"
                            CornerRadius="8" FontSize="14"/>
                    <Button Grid.Column="1"
                            x:Name="CreateButton"
                            Text="Create"
                            Clicked="OnCreateClicked"
                            BackgroundColor="#3B6D11"
                            TextColor="White"
                            CornerRadius="8"
                            FontAttributes="Bold"
                            FontSize="14"/>
                </Grid>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>
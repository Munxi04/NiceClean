<?xml version="1.0" encoding="utf-8"?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="NiceCleanApp.Pages.Controls.EventDetailPopup"
               Background="Transparent"
               CanBeDismissedByTappingOutsideOfPopup="True">

    <Border WidthRequest="320"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 16"
            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
            Padding="0">

        <VerticalStackLayout Spacing="0">

            <!-- Header bar -->
            <Grid x:Name="HeaderGrid"
                  Padding="20,16"
                  BackgroundColor="#3B6D11"
                  ColumnDefinitions="*,Auto">
                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label x:Name="TitleLabel"
                           FontSize="18" FontAttributes="Bold" TextColor="White"/>
                    <Label x:Name="SubtitleLabel"
                           FontSize="12" TextColor="#C5E49A"
                           MaxLines="2" LineBreakMode="TailTruncation"/>
                </VerticalStackLayout>
                <Button Grid.Column="1"
                        Text="✕" Clicked="OnCloseClicked"
                        BackgroundColor="Transparent" TextColor="White"
                        FontSize="18" Padding="0"
                        WidthRequest="36" HeightRequest="36"
                        VerticalOptions="Start"/>
            </Grid>

            <!-- Body -->
            <VerticalStackLayout Padding="20,16" Spacing="12">

                <!-- Status badge -->
                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                    <BoxView x:Name="StatusDot"
                             WidthRequest="10" HeightRequest="10"
                             CornerRadius="5" VerticalOptions="Center"/>
                    <Label x:Name="StatusLabel"
                           FontSize="14" FontAttributes="Bold"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"/>
                </HorizontalStackLayout>

                <BoxView HeightRequest="1" Color="#22000000"/>

                <!-- Info rows -->
                <Grid ColumnDefinitions="Auto,*"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                      ColumnSpacing="12" RowSpacing="10">

                    <Label Grid.Row="0" Grid.Column="0" Text="Date"
                           FontSize="13" TextColor="{AppThemeBinding Light=#888888, Dark=#AAAAAA}"/>
                    <Label Grid.Row="0" Grid.Column="1" x:Name="DateLabel"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"/>

                    <Label Grid.Row="1" Grid.Column="0" Text="Location"
                           FontSize="13" TextColor="{AppThemeBinding Light=#888888, Dark=#AAAAAA}"/>
                    <Label Grid.Row="1" Grid.Column="1" x:Name="LocationLabel"
                           FontSize="13" FontAttributes="Bold" LineBreakMode="WordWrap"
                           TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"/>

                    <Label Grid.Row="2" Grid.Column="0" Text="Pollution"
                           FontSize="13" TextColor="{AppThemeBinding Light=#888888, Dark=#AAAAAA}"/>
                    <Label Grid.Row="2" Grid.Column="1" x:Name="PollutionLabel"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"/>

                    <Label Grid.Row="3" Grid.Column="0" Text="Host"
                           FontSize="13" TextColor="{AppThemeBinding Light=#888888, Dark=#AAAAAA}"/>
                    <Label Grid.Row="3" Grid.Column="1" x:Name="HostLabel"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"/>

                    <Label Grid.Row="4" Grid.Column="0" Text="Participants"
                           FontSize="13" TextColor="{AppThemeBinding Light=#888888, Dark=#AAAAAA}"/>
                    <Label Grid.Row="4" Grid.Column="1" x:Name="ParticipantsLabel"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"/>
                </Grid>

                <!-- Busy / feedback -->
                <ActivityIndicator x:Name="BusyIndicator"
                                   IsRunning="False" IsVisible="False"
                                   Color="#3B6D11" HorizontalOptions="Center"/>
                <Label x:Name="FeedbackLabel"
                       IsVisible="False"
                       HorizontalTextAlignment="Center"
                       FontSize="13"/>

                <!-- Action buttons -->
                <Button x:Name="JoinButton"
                        IsVisible="False"
                        Text="🙋 Join this Clean Walk"
                        Clicked="OnJoinClicked"
                        BackgroundColor="#3B6D11" TextColor="White"
                        CornerRadius="8" FontSize="14" FontAttributes="Bold"
                        HeightRequest="44"/>

                <Button x:Name="LeaveButton"
                        IsVisible="False"
                        Text="Leave Clean Walk"
                        Clicked="OnLeaveClicked"
                        BackgroundColor="#FF3300" TextColor="White"
                        CornerRadius="8" FontSize="14" FontAttributes="Bold"
                        HeightRequest="44"/>

                <!-- Host controls -->
                <VerticalStackLayout x:Name="HostActions" IsVisible="False" Spacing="8">
                    <BoxView HeightRequest="1" Color="#22000000"/>
                    <Label Text="Host Controls"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#888888, Dark=#AAAAAA}"/>
                    <Button x:Name="StartButton"
                            IsVisible="False"
                            Text="▶ Start Event"
                            Clicked="OnStartClicked"
                            BackgroundColor="#3B6D11" TextColor="White"
                            CornerRadius="8" FontSize="14" HeightRequest="44"/>
                    <Button x:Name="EndButton"
                            IsVisible="False"
                            Text="⏹ End Event"
                            Clicked="OnEndClicked"
                            BackgroundColor="#888888" TextColor="White"
                            CornerRadius="8" FontSize="14" HeightRequest="44"/>
                    <Button x:Name="ReportButton"
                            IsVisible="False"
                            Text="✏️ Send Report"
                            Clicked="OnReportClicked"
                            BackgroundColor="#FF3300" TextColor="White"
                            CornerRadius="8" FontSize="14" HeightRequest="44"/>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>
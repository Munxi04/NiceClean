<?xml version="1.0" encoding="utf-8"?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="NiceCleanApp.Pages.Controls.EventReportPopup"
               Background="Transparent"
               CanBeDismissedByTappingOutsideOfPopup="False">

    <Border WidthRequest="320"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 16"
            BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
            Padding="0">

        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <Grid Padding="20,16"
                  BackgroundColor="#3B6D11"
                  ColumnDefinitions="*,Auto">
                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label Text="🧹 Clean-Up Report"
                           FontSize="18" FontAttributes="Bold" TextColor="White"/>
                    <Label Text="Tell us how much was collected"
                           FontSize="12" TextColor="#C5E49A"/>
                </VerticalStackLayout>
                <Button Grid.Column="1"
                        Text="✕" Clicked="OnSkipClicked"
                        BackgroundColor="Transparent" TextColor="White"
                        FontSize="18" Padding="0"
                        WidthRequest="36" HeightRequest="36"
                        VerticalOptions="Start"/>
            </Grid>

            <!-- Body -->
            <VerticalStackLayout Padding="20,18" Spacing="18">

                <!-- Number of bags -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="🛍️ Number of Bags"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#888888, Dark=#AAAAAA}"/>

                    <Grid ColumnDefinitions="44,*,44" ColumnSpacing="8">

                        <Button Grid.Column="0"
                                x:Name="DecrementButton"
                                Text="−" FontSize="20"
                                BackgroundColor="{AppThemeBinding Light=#EEEEEE, Dark=#3A3A3A}"
                                TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"
                                CornerRadius="8" HeightRequest="44"
                                Clicked="OnDecrementClicked"/>

                        <Border Grid.Column="1"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#444444}"
                                StrokeShape="RoundRectangle 10"
                                BackgroundColor="{AppThemeBinding Light=#F9F9F9, Dark=#333333}"
                                Padding="4,0">
                            <Label x:Name="BagCountLabel"
                                   Text="1"
                                   FontSize="20" FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}"/>
                        </Border>

                        <Button Grid.Column="2"
                                x:Name="IncrementButton"
                                Text="+" FontSize="20"
                                BackgroundColor="{AppThemeBinding Light=#EEEEEE, Dark=#3A3A3A}"
                                TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"
                                CornerRadius="8" HeightRequest="44"
                                Clicked="OnIncrementClicked"/>
                    </Grid>
                </VerticalStackLayout>

                <!-- Bag volume cards -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="📦 Bag Volume"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#888888, Dark=#AAAAAA}"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8"
                          RowDefinitions="Auto,Auto" RowSpacing="8">

                        <Border x:Name="SmallCard" Grid.Column="0" Grid.Row="0"
                                Padding="10,10" StrokeThickness="2"
                                Stroke="#3B6D11"
                                StrokeShape="RoundRectangle 10"
                                BackgroundColor="#3B6D11">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnVolumeSelected"
                                                      CommandParameter="Small"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="🪣" FontSize="22" HorizontalOptions="Center"/>
                                <Label x:Name="SmallLabel" Text="Small" FontSize="13" FontAttributes="Bold"
                                       TextColor="White" HorizontalOptions="Center"/>
                                <Label x:Name="SmallSubLabel" Text="~10 L" FontSize="11"
                                       TextColor="#C5E49A" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border x:Name="MediumCard" Grid.Column="1" Grid.Row="0"
                                Padding="10,10" StrokeThickness="2"
                                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#444444}"
                                StrokeShape="RoundRectangle 10"
                                BackgroundColor="{AppThemeBinding Light=#F9F9F9, Dark=#2C2C2C}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnVolumeSelected"
                                                      CommandParameter="Medium"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="🛢️" FontSize="22" HorizontalOptions="Center"/>
                                <Label x:Name="MediumLabel" Text="Medium" FontSize="13" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"
                                       HorizontalOptions="Center"/>
                                <Label x:Name="MediumSubLabel" Text="~30 L" FontSize="11"
                                       TextColor="{AppThemeBinding Light=#888888, Dark=#AAAAAA}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border x:Name="LargeCard" Grid.Column="0" Grid.Row="1"
                                Padding="10,10" StrokeThickness="2"
                                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#444444}"
                                StrokeShape="RoundRectangle 10"
                                BackgroundColor="{AppThemeBinding Light=#F9F9F9, Dark=#2C2C2C}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnVolumeSelected"
                                                      CommandParameter="Large"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="🗑️" FontSize="22" HorizontalOptions="Center"/>
                                <Label x:Name="LargeLabel" Text="Large" FontSize="13" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"
                                       HorizontalOptions="Center"/>
                                <Label x:Name="LargeSubLabel" Text="~60 L" FontSize="11"
                                       TextColor="{AppThemeBinding Light=#888888, Dark=#AAAAAA}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border x:Name="XLargeCard" Grid.Column="1" Grid.Row="1"
                                Padding="10,10" StrokeThickness="2"
                                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#444444}"
                                StrokeShape="RoundRectangle 10"
                                BackgroundColor="{AppThemeBinding Light=#F9F9F9, Dark=#2C2C2C}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnVolumeSelected"
                                                      CommandParameter="ExtraLarge"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="🚛" FontSize="22" HorizontalOptions="Center"/>
                                <Label x:Name="XLargeLabel" Text="Extra Large" FontSize="13" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"
                                       HorizontalOptions="Center"/>
                                <Label x:Name="XLargeSubLabel" Text="~100 L" FontSize="11"
                                       TextColor="{AppThemeBinding Light=#888888, Dark=#AAAAAA}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>

                    </Grid>
                </VerticalStackLayout>

                <!-- Live summary -->
                <Border BackgroundColor="{AppThemeBinding Light=#F0F7EB, Dark=#1E2E1A}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 10"
                        Padding="14,10">
                    <Label x:Name="SummaryLabel"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="#3B6D11"
                           HorizontalTextAlignment="Center"/>
                </Border>

                <!-- Error -->
                <Label x:Name="ErrorLabel"
                       IsVisible="False"
                       TextColor="#E53935"
                       FontSize="13"
                       HorizontalTextAlignment="Center"/>

                <!-- Busy -->
                <ActivityIndicator x:Name="BusyIndicator"
                                   IsRunning="False" IsVisible="False"
                                   Color="#3B6D11" HorizontalOptions="Center"/>

                <!-- Actions -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Button Grid.Column="0"
                            Text="Skip"
                            Clicked="OnSkipClicked"
                            BackgroundColor="{AppThemeBinding Light=#EEEEEE, Dark=#3A3A3A}"
                            TextColor="{AppThemeBinding Light=#444444, Dark=#CCCCCC}"
                            CornerRadius="8" FontSize="14"/>
                    <Button Grid.Column="1"
                            x:Name="SubmitButton"
                            Text="Submit"
                            Clicked="OnSubmitClicked"
                            BackgroundColor="#3B6D11"
                            TextColor="White"
                            CornerRadius="8"
                            FontAttributes="Bold"
                            FontSize="14"/>
                </Grid>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>

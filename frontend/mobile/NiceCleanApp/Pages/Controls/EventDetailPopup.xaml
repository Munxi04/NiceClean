<?xml version="1.0" encoding="utf-8"?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="NiceCleanApp.Pages.Controls.EventDetailPopup"
               Background="Transparent"
               CanBeDismissedByTappingOutsideOfPopup="True">

    <!-- Outer card -->
    <Border WidthRequest="340"
            Padding="0"
            StrokeThickness="0"
            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="20"/>
        </Border.StrokeShape>
        <Border.Shadow>
            <Shadow Brush="Black" Offset="0,4" Radius="16" Opacity="0.2"/>
        </Border.Shadow>

        <Grid RowDefinitions="Auto,*">

            <!-- Coloured header -->
            <Grid Grid.Row="0"
                  x:Name="HeaderGrid"
                  BackgroundColor="#3B6D11"
                  Padding="20,18"
                  ColumnDefinitions="*,Auto">
                <VerticalStackLayout Grid.Column="0" Spacing="3">
                    <Label x:Name="TitleLabel"
                           FontSize="17" FontAttributes="Bold" TextColor="White"/>
                    <Label x:Name="SubtitleLabel"
                           FontSize="12" TextColor="#CCE8B0"/>
                </VerticalStackLayout>
                <Button Grid.Column="1"
                        Text="✕" Clicked="OnCloseClicked"
                        BackgroundColor="Transparent" TextColor="White"
                        FontSize="18" WidthRequest="36" HeightRequest="36"
                        Padding="0" VerticalOptions="Start"/>
            </Grid>

            <!-- Body -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="20" Spacing="14">

                    <!-- Status indicator -->
                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                        <BoxView x:Name="StatusDot"
                                 WidthRequest="12" HeightRequest="12"
                                 CornerRadius="6" VerticalOptions="Center"/>
                        <Label x:Name="StatusLabel"
                               FontSize="14" FontAttributes="Bold"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"/>
                    </HorizontalStackLayout>

                    <BoxView HeightRequest="1"
                             BackgroundColor="{AppThemeBinding Light=#EEEEEE, Dark=#3A3A3A}"/>

                    <!-- Info grid -->
                    <Grid ColumnDefinitions="130,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">

                        <Label Grid.Row="0" Grid.Column="0" Text="📅 Date"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#888888, Dark=#888888}"/>
                        <Label Grid.Row="0" Grid.Column="1" x:Name="DateLabel"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"/>

                        <Label Grid.Row="1" Grid.Column="0" Text="📍 Location"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#888888, Dark=#888888}"/>
                        <Label Grid.Row="1" Grid.Column="1" x:Name="LocationLabel"
                               FontSize="13" LineBreakMode="WordWrap"
                               TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"/>

                        <Label Grid.Row="2" Grid.Column="0" Text="⚠️ Pollution"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#888888, Dark=#888888}"/>
                        <Label Grid.Row="2" Grid.Column="1" x:Name="PollutionLabel"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"/>

                        <Label Grid.Row="3" Grid.Column="0" Text="👤 Host"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#888888, Dark=#888888}"/>
                        <Label Grid.Row="3" Grid.Column="1" x:Name="HostLabel"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"/>
                        
                        <Label Grid.Row="4" Grid.Column="0" Text="👥 Participants"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#888888, Dark=#888888}"/>
                        <Label Grid.Row="4" Grid.Column="1" x:Name="ParticipantsLabel"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}"/>
                    </Grid>

                    <BoxView HeightRequest="1"
                             BackgroundColor="{AppThemeBinding Light=#EEEEEE, Dark=#3A3A3A}"/>

                    <!-- Busy / feedback -->
                    <ActivityIndicator x:Name="BusyIndicator"
                                       IsRunning="False" IsVisible="False"
                                       Color="#3B6D11" HorizontalOptions="Center"/>

                    <Label x:Name="FeedbackLabel"
                           IsVisible="False"
                           HorizontalTextAlignment="Center"
                           FontSize="13"/>

                    <!-- Join (participant) -->
                    <Button x:Name="JoinButton"
                            IsVisible="False"
                            Text="🙋 Join this Clean Walk"
                            Clicked="OnJoinClicked"
                            BackgroundColor="#3B6D11" TextColor="White"
                            CornerRadius="12" FontSize="14" FontAttributes="Bold"
                            HeightRequest="48"/>

                    <!-- Host controls -->
                    <VerticalStackLayout x:Name="HostActions" IsVisible="False" Spacing="10">
                        <Label Text="Host Controls"
                               FontSize="13" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#888888, Dark=#888888}"/>
                        <Button x:Name="StartButton"
                                IsVisible="False"
                                Text="▶  Start Event"
                                Clicked="OnStartClicked"
                                BackgroundColor="#3B6D11" TextColor="White"
                                CornerRadius="12" FontSize="14" HeightRequest="46"/>
                        <Button x:Name="EndButton"
                                IsVisible="False"
                                Text="⏹  End Event"
                                Clicked="OnEndClicked"
                                BackgroundColor="#888888" TextColor="White"
                                CornerRadius="12" FontSize="14" HeightRequest="46"/>
                    </VerticalStackLayout>

                    <!-- Close -->
                    <Button Text="Close"
                            Clicked="OnCloseClicked"
                            Margin="0,4,0,0"
                            BackgroundColor="{AppThemeBinding Light=#EEEEEE, Dark=#3A3A3A}"
                            TextColor="{AppThemeBinding Light=#444444, Dark=#CCCCCC}"
                            CornerRadius="12" FontSize="14" HeightRequest="46"/>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Border>
</toolkit:Popup>

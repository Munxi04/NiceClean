<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Class="NiceCleanApp.Pages.Controls.PinValidationPopup"
    CanBeDismissedByTappingOutsideOfPopup="False"
    Background="Transparent">

    <Border
        WidthRequest="320"
        StrokeThickness="0"
        StrokeShape="RoundRectangle 16"
        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
        Padding="0">

        <VerticalStackLayout Spacing="0">

            <!-- ── Header bar ── -->
            <Grid
                Padding="20,16"
                BackgroundColor="#3B6D11"
                ColumnDefinitions="*,Auto">

                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label
                        x:Name="TitleLabel"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="White" />
                    <Label
                        x:Name="SubtitleLabel"
                        FontSize="12"
                        TextColor="#C5E49A"
                        MaxLines="2"
                        LineBreakMode="TailTruncation" />
                </VerticalStackLayout>

                <Button
                    Grid.Column="1"
                    Text="✕"
                    TextColor="White"
                    BackgroundColor="Transparent"
                    FontSize="18"
                    Padding="0"
                    WidthRequest="36"
                    HeightRequest="36"
                    VerticalOptions="Start"
                    Clicked="OnCloseClicked" />
            </Grid>

            <!-- ── Body ── -->
            <VerticalStackLayout Padding="20,14" Spacing="12">

                <!-- Status badge -->
                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                    <BoxView
                        x:Name="StatusDot"
                        WidthRequest="10"
                        HeightRequest="10"
                        CornerRadius="5"
                        VerticalOptions="Center" />
                    <Label
                        x:Name="StatusLabel"
                        FontSize="14"
                        FontAttributes="Bold"
                        VerticalOptions="Center"
                        TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}" />
                </HorizontalStackLayout>

                <BoxView HeightRequest="1" Color="#22000000" />

                <!-- Info rows -->
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto"
                      ColumnSpacing="12" RowSpacing="10">

                    <Label Grid.Row="0" Grid.Column="0" Text="Type"
                           FontSize="13" TextColor="{AppThemeBinding Light=#888888, Dark=#AAAAAA}" />
                    <Label Grid.Row="0" Grid.Column="1" x:Name="TypeLabel"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}" />

                    <Label Grid.Row="1" Grid.Column="0" Text="Severity"
                           FontSize="13" TextColor="{AppThemeBinding Light=#888888, Dark=#AAAAAA}" />
                    <Label Grid.Row="1" Grid.Column="1" x:Name="SeverityLabel"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}" />

                    <Label Grid.Row="2" Grid.Column="0" Text="Radius"
                           FontSize="13" TextColor="{AppThemeBinding Light=#888888, Dark=#AAAAAA}" />
                    <Label Grid.Row="2" Grid.Column="1" x:Name="RadiusLabel"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}" />

                    <Label Grid.Row="3" Grid.Column="0" Text="Reported"
                           FontSize="13" TextColor="{AppThemeBinding Light=#888888, Dark=#AAAAAA}" />
                    <Label Grid.Row="3" Grid.Column="1" x:Name="DateLabel"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}" />
                </Grid>

                <BoxView HeightRequest="1" Color="#22000000" />

                <!-- Proximity callout -->
                <Border
                    BackgroundColor="#FFF8E7"
                    StrokeShape="RoundRectangle 8"
                    StrokeThickness="0"
                    Padding="12,8">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="📍" FontSize="16" VerticalOptions="Center" />
                        <Label
                            Text="You are nearby this pollution spot. Can you confirm its current state?"
                            FontSize="12"
                            TextColor="#7A5800"
                            LineBreakMode="WordWrap"
                            HorizontalOptions="Fill" />
                    </HorizontalStackLayout>
                </Border>

                <!-- Action buttons -->
                <!-- "Still here" button — always shown for Unverified pins -->
                <Button
                    x:Name="VerifyButton"
                    Text="✅  Still here — Confirm"
                    BackgroundColor="#3B6D11"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="44"
                    FontSize="14"
                    IsVisible="True"
                    Clicked="OnVerifyClicked" />

                <!-- "Cleaned" button — always shown -->
                <Button
                    x:Name="CleanedButton"
                    Text="🧹  Area is now clean"
                    BackgroundColor="#1A5276"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="44"
                    FontSize="14"
                    Clicked="OnMarkCleanedClicked" />

                <!-- Busy indicator -->
                <ActivityIndicator
                    x:Name="BusyIndicator"
                    IsVisible="False"
                    IsRunning="False"
                    Color="#3B6D11"
                    HorizontalOptions="Center" />

            </VerticalStackLayout>
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>

<?xml version="1.0" encoding="utf-8"?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="NiceCleanApp.Pages.Controls.CreateEventPopup"
               Background="Transparent"
               CanBeDismissedByTappingOutsideOfPopup="False">

    <!-- Outer card -->
    <Border WidthRequest="340"
            Padding="0"
            StrokeThickness="0"
            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="20"/>
        </Border.StrokeShape>
        <Border.Shadow>
            <Shadow Brush="Black" Offset="0,4" Radius="16" Opacity="0.2"/>
        </Border.Shadow>

        <Grid RowDefinitions="Auto,*">

            <!-- Header -->
            <Grid Grid.Row="0"
                  BackgroundColor="#3B6D11"
                  Padding="20,16"
                  ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       Text="🌿 New Clean Walk"
                       FontSize="18" FontAttributes="Bold"
                       TextColor="White" VerticalOptions="Center"/>
                <Button Grid.Column="1"
                        Text="✕" Clicked="OnCloseClicked"
                        BackgroundColor="Transparent" TextColor="White"
                        FontSize="18" WidthRequest="36" HeightRequest="36" Padding="0"/>
            </Grid>

            <!-- Form -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="20" Spacing="16">

                    <!-- Pin picker -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="📍 Pollution Spot"
                               FontSize="13" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}"/>
                        <Border Padding="4,0" StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#444444}"
                                BackgroundColor="{AppThemeBinding Light=#F9F9F9, Dark=#333333}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Picker x:Name="PinPicker"
                                    Title="Select a pin…"
                                    FontSize="14"
                                    TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}"
                                    TitleColor="{AppThemeBinding Light=#999999, Dark=#777777}"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Date -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="📅 Date"
                               FontSize="13" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}"/>
                        <Border Padding="12,6" StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#444444}"
                                BackgroundColor="{AppThemeBinding Light=#F9F9F9, Dark=#333333}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <DatePicker x:Name="EventDatePicker"
                                        FontSize="14"
                                        TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Time -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="🕐 Time"
                               FontSize="13" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}"/>
                        <Border Padding="12,6" StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#444444}"
                                BackgroundColor="{AppThemeBinding Light=#F9F9F9, Dark=#333333}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <TimePicker x:Name="EventTimePicker"
                                        FontSize="14"
                                        TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Error -->
                    <Label x:Name="ErrorLabel"
                           IsVisible="False"
                           TextColor="#E53935"
                           FontSize="13"
                           HorizontalTextAlignment="Center"/>

                    <!-- Busy -->
                    <ActivityIndicator x:Name="BusyIndicator"
                                       IsRunning="False" IsVisible="False"
                                       Color="#3B6D11" HorizontalOptions="Center"/>

                    <!-- Actions -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,4,0,0">
                        <Button Grid.Column="0"
                                Text="Cancel"
                                Clicked="OnCloseClicked"
                                BackgroundColor="{AppThemeBinding Light=#EEEEEE, Dark=#3A3A3A}"
                                TextColor="{AppThemeBinding Light=#444444, Dark=#CCCCCC}"
                                CornerRadius="12" FontSize="14"/>
                        <Button Grid.Column="1"
                                x:Name="CreateButton"
                                Text="Create Event"
                                Clicked="OnCreateClicked"
                                BackgroundColor="#3B6D11"
                                TextColor="White"
                                CornerRadius="12"
                                FontAttributes="Bold"
                                FontSize="14"/>
                    </Grid>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Border>
</toolkit:Popup>

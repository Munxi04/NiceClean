<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="NiceCleanApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:NiceCleanApp.Pages"
    Shell.FlyoutBehavior="Disabled"
    Title="NiceCleanApp">

    <ShellContent
        Title="Auth"
        ContentTemplate="{DataTemplate pages:AuthPage}"
        Route="AuthPage" />
    <ShellContent 
        Title="Map" 
        ContentTemplate="{DataTemplate pages:MapPage}"
        Route="MapPage" />

</Shell>